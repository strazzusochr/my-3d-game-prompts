{
  "name": "corona-control-ultimate",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently \"npm run dev\" \"node server/server.js\" --names \"vite,socket\" --prefix-colors \"cyan,yellow\"",
    "dev:all:safe": "node scripts/dev-all-safe.mjs",
    "prestream": "node scripts/security/port-check.mjs --mode=stream && node scripts/security/resource-guard.mjs",
    "preautonomy:proof": "node scripts/security/port-check.mjs --mode=autonomy && node scripts/security/resource-guard.mjs",
    "preautonomy:full": "node scripts/security/port-check.mjs --mode=autonomy && node scripts/security/resource-guard.mjs",
    "build": "vite build",
    "start": "node server/server-prod.mjs",
    "stream": "node scripts/security/run-stream-secure.mjs --profile=low",
    "stream:medium": "node scripts/security/run-stream-secure.mjs --profile=medium",
    "stream:high": "node scripts/security/run-stream-secure.mjs --profile=high",
    "stream:aaa": "node scripts/security/run-stream-secure.mjs --profile=aaa",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "port:check": "node scripts/security/port-check.mjs --mode=all",
    "security:memory-validate": "node scripts/security/validate-memory-logs.mjs",
    "security:resource-guard": "node scripts/security/resource-guard.mjs",
    "verify:live": "node scripts/verify-live-stack.mjs",
    "security:ci-local": "npm run lint && npm exec vitest run && npm run build && npm audit --audit-level=high && npm sbom --sbom-format spdx > sbom.spdx.json",
    "autonomy:proof": "node scripts/autonomy-proof.mjs",
    "autonomy-proof": "npm run autonomy:proof",
    "autonomy:full": "node scripts/autonomy-full.mjs",
    "autonomy-full": "npm run autonomy:full"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "0.12.0",
    "@fontsource/outfit": "^5.2.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@react-three/rapier": "^2.2.0",
    "compression": "^1.8.1",
    "express": "^4.22.1",
    "helmet": "^8.1.0",
    "leva": "^0.10.1",
    "postprocessing": "^6.38.2",
    "puppeteer": "^24.6.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "stats.js": "^0.17.0",
    "three": "^0.182.0",
    "three-stdlib": "^2.36.1",
    "winston": "^3.19.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/stats.js": "^0.17.4",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
