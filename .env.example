# Clone-safe port configuration
# Copy to .env and adjust if ports are occupied on your machine.

# Vite dev server port
VITE_PORT=5173
DEV_PORT=3001

# Socket.IO game server port (server/server.js)
SOCKET_PORT=3000
WS_PORT=3000

# Public stream/prod port (server/stream-server.mjs and server/server-prod.mjs)
PORT=7860
STREAM_PORT=7860

# Internal render port used by Puppeteer (stream server only)
INTERNAL_PORT=3099
AUTONOMY_PORT=3099

# Renderer backend: hardware (recommended) or software
RENDER_BACKEND=hardware

# Headless mode for Chromium: false|true|new
HEADLESS_MODE=new

# Optional: force a specific browser executable (recommended on Windows when Chromium fails)
# BROWSER_EXECUTABLE_PATH=C:\\Program Files\\BraveSoftware\\Brave-Browser-Nightly\\Application\\brave.exe

# Optional stream defaults
# STREAM_PROFILE=low
# STREAM_WIDTH=960
# STREAM_HEIGHT=540
# STREAM_JPEG_QUALITY=35
# STREAM_FPS=24

# Security defaults (secrets never commit real values)
ZERO_GRAD_MODE=true
ZERO_GRAD_LOG_ENCRYPTION=true
ZERO_GRAD_REPLAY_PROTECTION=true

# Optional secrets (set in GitHub Secrets / local .env only)
# WS_SHARED_TOKEN=replace_me
# API_ADMIN_TOKEN=replace_me
# ZERO_GRAD_MASTER_KEY=replace_me
# ZERO_GRAD_HMAC_KEY=replace_me

# Allowed web origins for local clients
ALLOWED_ORIGINS=http://127.0.0.1:3001,http://localhost:3001,http://127.0.0.1:7860,http://localhost:7860

# Home-PC only compute guard
NO_REMOTE_COMPUTE=true
ALLOWED_COMPUTE_HOSTS=127.0.0.1,localhost
# RENDER_TARGET_HOST=localhost

# Runtime guard thresholds
MAX_HEAP_MB=3072
MAX_CPU_LOAD_RATIO=0.95
API_RATE_WINDOW_MS=10000
API_RATE_MAX_REQUESTS=30
WS_RATE_WINDOW_MS=10000
WS_RATE_MAX_EVENTS=300