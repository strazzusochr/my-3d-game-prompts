# Clone-safe port configuration
# Copy to .env and adjust if ports are occupied on your machine.

# Vite dev server port
VITE_PORT=5173

# Socket.IO game server port (server/server.js)
SOCKET_PORT=3000

# Public stream/prod port (server/stream-server.mjs and server/server-prod.mjs)
PORT=7860

# Internal render port used by Puppeteer (stream server only)
INTERNAL_PORT=3099

# Renderer backend: hardware (recommended) or software
RENDER_BACKEND=hardware

# Headless mode for Chromium: false|true|new
HEADLESS_MODE=new

# Optional: force a specific browser executable (recommended on Windows when Chromium fails)
# BROWSER_EXECUTABLE_PATH=C:\\Program Files\\BraveSoftware\\Brave-Browser-Nightly\\Application\\brave.exe

# Optional stream defaults
# STREAM_PROFILE=low
# STREAM_WIDTH=960
# STREAM_HEIGHT=540
# STREAM_JPEG_QUALITY=35
# STREAM_FPS=24